{
	"name": "DS_SqlTable_Parquet1",
	"properties": {
		"linkedServiceName": {
			"referenceName": "ADLS_SQL_PARQUET_MIGRATION",
			"type": "LinkedServiceReference"
		},
		"parameters": {
			"Table_Name": {
				"type": "string"
			}
		},
		"annotations": [],
		"type": "Parquet",
		"typeProperties": {
			"location": {
				"type": "AzureBlobFSLocation",
				"fileName": "@concat(dataset().Table_Name,'_',formatDateTime(utcNow(),'yyyyMMddHHmmss'),'.parquet')",
				"folderPath": {
					"value": "@concat(dataset().Table_Name,'/',formatDateTime(utcNow(),'yyyy/MM/dd'))\n",
					"type": "Expression"
				},
				"fileSystem": {
					"value": "retaildw",
					"type": "Expression"
				}
			},
			"compressionCodec": "snappy"
		},
		"schema": [
			{
				"name": "geolocation_zip_code_prefix",
				"type": "UTF8"
			},
			{
				"name": "geolocation_lat",
				"type": "UTF8"
			},
			{
				"name": "geolocation_lng",
				"type": "UTF8"
			},
			{
				"name": "geolocation_city",
				"type": "UTF8"
			},
			{
				"name": "geolocation_state",
				"type": "UTF8"
			}
		]
	}
}